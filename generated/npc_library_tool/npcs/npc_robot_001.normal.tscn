[node name="故障机器人" type="Node2D" unique_id=1911344473]
y_sort_enabled = true
scale = Vector2(3, 3)
script = ExtResource("1_3gxb2")
npc_display_name = "故障机器人"
dialogue_lines = PackedStringArray("像素交流群 群号：1079961300，密码：bimelona", "广告：联系 QQ 719937402，可咨询收费版插件、AI 像素技术培训、游戏资源解包培训。", "像素素材生成培训：从像素角色生成流程到地形生成流程，除基础教学外会给常规视频里没有的技巧；2 小时，远程桌面加语音，效果是能独立定制自己的像素风格（有限）。", "像素资源提取培训：对 UE5 和 Unity 像素游戏提取做简单培训，完全经验之谈，外界无参考教程；1~2 小时，远程桌面加语音。", "游戏挂机脚本培训：安卓模拟器自动化写脚本，本人熟悉工作室脚本流程，帮助学员快速上手安卓游戏自动化脚本编写，常规游戏可自己写挂机脚本。", "Godot 快速入门培训：AI 结合 Godot 开发技巧；另有满血版插件，带新模板并支持 HD2D 版本。")
npc_portrait_path = "res://AI资源库/一图全动作/故障机器人/robot_thumb.png"
enable_ai_logic = true
ai_mode = "wander"
player_group_candidates = PackedStringArray("player", "Player")
player_name_keywords = PackedStringArray("player", "hero", "main", "character")
interact_action_candidates = PackedStringArray("interact", "ui_accept")
interact_key_fallbacks = PackedInt32Array(69, 70, 4194309)
metadata/ai_path_points = [{
"dir": "right",
"dist": 48.0
}]
metadata/npc_id = "npc_robot_001"
metadata/npc_json_path = "res://AI资源库/一图全动作/故障机器人/npc.json"
metadata/npc_style = "wasteland_scifi"
metadata/npc_category = "combat"
metadata/npc_data = {
"assets": {
"spritePath": "./robot_sprite.png",
"thumbPath": "./robot_thumb.png"
},
"ext": {
"animationParams": "standard_humanoid_4dir",
"battleProfile": {
"engageRadius": 400.0,
"leashRadius": 700.0,
"preferredRange": 250.0
},
"cardPreviewAnim": "idle_down",
"dialogueState": "first_meet_unlocked",
"librarySortPriority": 8.0,
"localization": {
"appearance": {
"en": "",
"ja": "",
"zh": "故障机器人为金属机械身躯，外壳带有故障流光与电路划痕，核心能源舱持续闪烁蓝光，机械关节灵活运转，行动时伴随轻微的电流滋滋声。"
},
"background": {
"en": "",
"ja": "",
"zh": "故障机器人是杀戮尖塔内诞生的自主机械生命体，因系统故障挣脱程式控制，擅长雷电法术与爆发输出，依靠能量核心维持运作，需要定期校准修复故障。"
},
