    "ext": {
        "localization": {
            "appearance": {
                "zh": "凌乱金发扎成高马尾，穿着白色紧身背心与磨损的深色牛仔裤，手臂肌肉线条清晰。腰间斜跨弹药带，大腿挂着工具包与Mk 2手榴弹。脚蹬一双带金属底的工作靴，手中紧握一把改装后的双管霰弹枪。",
                "en": "Messy blonde hair tied in a high ponytail. She wears a white tank top and worn dark jeans, showing defined muscles. A bandolier crosses her chest, with a tool bag and Mk 2 grenades on her thighs. Her metal-soled boots and modified double-barrel shotgun define her rugged look."
            },
            "background": {
                "zh": "传闻中红狼曾停留过的修理厂遗孤。她对成为最强猎人毫无兴趣，唯一的执念是收集顶级零件组装出能穿越死亡沙漠的“梦幻战车”。虽然身处末日，却始终保持着一种无畏的自信。",
                "en": "An orphan from a workshop where the legendary 'Red Wolf' once stayed. Uninterested in fame, she hunts monsters solely to scavenge rare parts for her 'Dream Tank'. She remains a stoic optimist despite the harsh wasteland."
            },
            "dialogues": {
                "greeting": {
                    "zh": "像素交流群 群号：1079961300，密码：bimelona别看我小，我双手举霰弹枪的准头比你见过的怪物都稳。要雇佣我吗？",
                    "en": "Hey! Don't let my size fool you. My aim with this shotgun is steadier than any monster you've seen. Looking to hire me?"
                },
                "shopOpen": {
                    "zh": "像素交流群 群号：1079961300，密码：bimelona",
                    "en": "As long as you fill my tank with premium fuel, we can talk business."
                },
                "battle_start": {
                    "zh": "像素交流群 群号：1079961300，密码：bimelona别让那家伙碰坏了我们要拆的零件！",
                    "en": "Pochi, get ready! Don't let that thing damage the parts we're scavenging!"
                }
            }
        },
        "animationParams": "humanoid_combatant_female",
        "otherPayload": {
            "companion": "Pochi (Cyber-dog with MG)",
            "weaponType": "Shotgun / Explosives",
            "techLevel": 4
